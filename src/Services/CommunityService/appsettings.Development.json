{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "Microsoft.AspNetCore.SignalR": "Debug",
      "Microsoft.AspNetCore.Http.Connections": "Debug"
    }
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyForJWTTokenGenerationAtLeast32Characters",
    "Issuer": "WritingPlatform",
    "Audience": "WritingPlatformUsers",
    "ExpireMinutes": 60
  },
  "AI": {
    "Provider": "Mock",
    "ApiKey": "your-api-key-here",
    "BaseUrl": "https://api.example.com/v1/",
    "TimeoutSeconds": 30,
    "MaxRetries": 3
  },
  "ConnectionStrings": {
    "AIDatabase": "Server=localhost;Port=3306;Database=WritingPlatformAI;User=root;Password=yourpassword;",
    "SearchDatabase": "Server=localhost;Port=3306;Database=writing_platform_search_dev;Uid=root;Pwd=password;Pooling=true;MinimumPoolSize=10;MaximumPoolSize=500;ConnectionIdleTimeout=300;ConnectionLifeTime=1800;",
    "Redis": "localhost:6379,abortConnect=false,connectTimeout=5000,syncTimeout=5000"
  },
  "ServiceUrls": {
    "UserService": "http://localhost:5000",
    "WritingService": "http://localhost:5001",
    "CommunityService": "http://localhost:5002"
  },
  "Search": {
    "MaxQueryLength": 200,
    "DefaultPageSize": 20,
    "MaxPageSize": 100,
    "SuggestionsLimit": 10,
    "CacheDurationMinutes": 1
  },
  "Payment": {
    "DefaultCurrency": "CNY",
    "DefaultTimeoutMinutes": 30,
    "CallbackBaseUrl": "https://yourdomain.com/api/payment/callback",
    "NotifyUrl": "https://yourdomain.com/api/payment/notify"
  },
  "Alipay": {
    "AppId": "your-app-id",
    "AppPrivateKey": "your-app-private-key",
    "AlipayPublicKey": "alipay-public-key",
    "SignType": "RSA2",
    "Charset": "UTF-8",
    "GatewayUrl": "https://openapi.alipay.com/gateway.do",
    "Sandbox": true,
    "SandboxGatewayUrl": "https://openapi.alipaydev.com/gateway.do"
  },
  "WeChatPay": {
    "AppId": "your-wechat-app-id",
    "MchId": "your-mch-id",
    "ApiKey": "your-api-key",
    "CertPath": "path/to/cert.p12",
    "Sandbox": true
  },
  "FileStorage": {
    "UploadPath": "wwwroot/uploads",
    "MaxFileSize": 104857600,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".pdf", ".doc", ".docx", ".txt", ".mp4", ".mp3", ".zip"],
    "BaseUrl": "http://localhost:5006"
  }
} 